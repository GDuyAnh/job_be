# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=password
DB_DATABASE=nestjs_auth
# WARNING: Set DB_SYNCHRONIZE=true only when you want TypeORM to automatically sync schema
# This can cause data loss if entity definitions change. Use migrations in production instead.
DB_SYNCHRONIZE=false

# JWT
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=1d

# App
PORT=8080
NODE_ENV=development

# Email Configuration (SMTP)
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM_NAME=TopViec
# FRONTEND_URL=http://localhost:3001

# Outlook example:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=your-email@outlook.com
# SMTP_PASS=your-password

# Yahoo example:
# SMTP_HOST=smtp.mail.yahoo.com
# SMTP_PORT=587
# SMTP_USER=your-email@yahoo.com
# SMTP_PASS=your-app-password

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=TopViec
FRONTEND_URL=http://localhost:3001 